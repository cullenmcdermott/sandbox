# Build artifacts
runner/node_modules/
runner/dist/

# Go build output (root binary only — anchored so it does not also ignore the
# cmd/sandbox/ source package). runner/package-lock.json is intentionally NOT
# ignored: it is committed so the runner image builds reproducibly via `npm ci`.
/sandbox

# Cross-compiled / scratch binaries that must never be committed via `git add -A`
/dist/
/mockup
/tuikit-demo
# `go build ./cmd/gen-eventschema` output (the generator is run via `go run` in
# `just gen`; a built binary must never be committed).
/gen-eventschema

# KIND local dev cluster (dev/local): the local kubeconfig and any provider-secret
# overlay are machine-local and may carry credentials — never commit them.
dev/local/.kubeconfig
dev/local/secret.local.yaml

.DS_STORE
