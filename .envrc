# Auto-activate the project's Flox environment for anyone with direnv installed.
#
# The env pins the FULL dev/CI toolchain so nothing leaks from the laptop:
#   go 1.26, node 24, gcc, git; ctlptl, kind, docker(-client CLI), tilt, kubectl,
#   helm, crictl, mutagen; golangci-lint 2.12.2 (CI pin), jq.
# The Docker daemon (Colima) and Hall (image delivery) are host daemons, not here.
# `just doctor` verifies every required tool resolves from $FLOX_ENV.
# See .flox/env/manifest.toml.
#
# Requires: direnv (https://direnv.net) and flox (https://flox.dev/download).
# Without direnv you can still get the same shell with `flox activate`, and the
# justfile recipes self-activate via `flox activate --` when run outside the env.

# Re-evaluate when the env definition changes so direnv reloads automatically.
watch_file .flox/env/manifest.toml
watch_file .flox/env/manifest.lock

# Non-interactive in-place activation: flox prints an activation script on stdout
# when stdout is not a TTY, which direnv evaluates into the current environment.
eval "$(flox activate)"
